# ZTLP Bootstrap Server — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# ── Required ──────────────────────────────────────────────
# Generate with: ruby -rsecurerandom -e 'puts SecureRandom.hex(64)'
SECRET_KEY_BASE=

# ── Encryption (for SSH key storage at rest) ──────────────
# Generate each with: ruby -rsecurerandom -e 'puts SecureRandom.hex(16)'
# ⚠️  If not set, random keys are generated on startup — SSH keys in DB
#     will be unreadable after container restart!
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# ── Optional ──────────────────────────────────────────────
# Port to expose (default: 3000)
# PORT=3000

# Path to ztlp CLI binary (default: ztlp, assumed in PATH)
# ZTLP_CLI_PATH=ztlp

# ActionCable adapter: async (default, no deps) or redis
# ACTION_CABLE_ADAPTER=async
# REDIS_URL=redis://localhost:6379/1
