*.gem
*.rbc
/.config
/coverage/
/InstalledFiles
/pkg/
/spec/reports/
/spec/examples.txt
/test/tmp/
/test/version_tmp/
/tmp/

# Bundler
/.bundle
/vendor/bundle

# SQLite
/db/*.sqlite3
/db/*.sqlite3-journal
/db/*.sqlite3-shm
/db/*.sqlite3-wal

# Environment
.env
.env.local
.env.*.local

# Rails
/log/*
/storage/*
!/log/.keep
!/storage/.keep
/tmp/

# Node
/node_modules/
/yarn-error.log

# Misc
.byebug_history
.ruby-version
.ruby-gemset

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Credentials
config/master.key
config/credentials/*.key

