<div class="sm:flex sm:items-center sm:justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Admin Users</h1>
    <p class="mt-1 text-sm text-gray-500">Manage administrator accounts for ZTLP Bootstrap.</p>
  </div>
  <div class="mt-4 sm:mt-0">
    <%= link_to new_admin_user_path, class: "inline-flex items-center rounded-md bg-ztlp-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-ztlp-700" do %>
      <span class="mr-1">+</span> New Admin User
    <% end %>
  </div>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Login</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @admin_users.each do |admin| %>
        <tr>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="flex items-center">
              <div class="flex-shrink-0 h-8 w-8 rounded-full bg-ztlp-600 flex items-center justify-center">
                <span class="text-xs font-medium text-white"><%= admin.name.first(2).upcase %></span>
              </div>
              <div class="ml-3">
                <div class="text-sm font-medium text-gray-900"><%= admin.name %></div>
                <% if admin == current_admin %>
                  <span class="text-xs text-ztlp-600">(you)</span>
                <% end %>
              </div>
            </div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= admin.email %></td>
          <td class="px-6 py-4 whitespace-nowrap">
            <% role_color = case admin.role
               when "super_admin" then "bg-purple-100 text-purple-800"
               when "admin" then "bg-blue-100 text-blue-800"
               when "read_only" then "bg-gray-100 text-gray-800"
               end %>
            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= role_color %>">
              <%= admin.role.titleize %>
            </span>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <% if admin.last_login_at %>
              <div><%= time_ago_short(admin.last_login_at) %></div>
              <div class="text-xs text-gray-400"><%= admin.last_login_ip %></div>
            <% else %>
              <span class="text-gray-400">Never</span>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <% if admin.locked? %>
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-red-100 text-red-800">
                🔒 Locked (<%= admin.lockout_minutes_remaining %>m)
              </span>
            <% else %>
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-green-100 text-green-800">
                Active
              </span>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
            <div class="flex items-center justify-end space-x-2">
              <%= link_to "Edit", edit_admin_user_path(admin), class: "text-ztlp-600 hover:text-ztlp-800 font-medium" %>
              <% if admin.locked? %>
                <%= button_to "Unlock", unlock_admin_user_path(admin), method: :post, class: "text-amber-600 hover:text-amber-800 font-medium" %>
              <% end %>
              <% unless admin == current_admin %>
                <%= button_to "Delete", admin_user_path(admin), method: :delete,
                    data: { turbo_confirm: "Are you sure you want to delete #{admin.name}?" },
                    class: "text-red-600 hover:text-red-800 font-medium" %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
