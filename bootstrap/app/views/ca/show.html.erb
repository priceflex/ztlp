<div class="mb-6">
  <nav class="text-sm text-gray-500 mb-2">
    <%= link_to @network.name, @network, class: "hover:text-gray-700" %> /
    <span class="text-gray-700">Certificate Authority</span>
  </nav>
  <div class="sm:flex sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Certificate Authority</h1>
      <p class="mt-1 text-sm text-gray-500">Internal TLS CA for <%= @network.zone %></p>
    </div>
  </div>
</div>

<% if @status[:initialized] %>
  <!-- CA Status -->
  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">CA Status</h2>
    <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <dt class="text-sm font-medium text-gray-500">Zone</dt>
        <dd class="text-sm text-gray-900"><%= @status[:zone] %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Created</dt>
        <dd class="text-sm text-gray-900"><%= @status[:created_at] %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Active Certificates</dt>
        <dd class="text-sm text-gray-900"><%= @status[:active_certs] %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Expiring Soon (30d)</dt>
        <dd class="text-sm <%= @status[:expiring_soon].to_i > 0 ? 'text-amber-600 font-semibold' : 'text-gray-900' %>">
          <%= @status[:expiring_soon] %>
        </dd>
      </div>
      <% if @status[:root_key] %>
        <div class="sm:col-span-2">
          <dt class="text-sm font-medium text-gray-500">Root Key (Public)</dt>
          <dd class="text-xs font-mono text-gray-600 break-all"><%= @status[:root_key] %></dd>
        </div>
      <% end %>
    </dl>
  </div>

  <!-- Key Storage Warning -->
  <div class="bg-amber-50 border-l-4 border-amber-500 p-4 mt-4">
    <div class="flex">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="ml-3">
        <h3 class="text-sm font-medium text-amber-800">Root CA Key Stored on Filesystem</h3>
        <p class="mt-1 text-sm text-amber-700">
          The root CA private key is currently stored as an encrypted file on the NS server.
          For production deployments, we strongly recommend using a 
          <strong>hardware security module</strong> (YubiKey, TPM) via the ZTLP Signing Oracle
          to ensure the root key never exists on disk.
        </p>
        <p class="mt-2 text-sm text-amber-700">
          <a href="https://github.com/priceflex/ztlp/blob/main/docs/SIGNING-ORACLE.md" 
             target="_blank" class="font-medium text-amber-800 underline hover:text-amber-900">
            Read the Signing Oracle documentation →
          </a>
        </p>
      </div>
    </div>
  </div>

  <!-- Actions -->
  <div class="flex space-x-4 mb-6">
    <%= link_to "Export Root Certificate", export_root_network_ca_path(@network),
        class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
    <%= button_to "Rotate Intermediate CA", rotate_intermediate_network_ca_path(@network),
        method: :post,
        data: { confirm: "This will generate a new intermediate CA. Existing certs remain valid. Continue?" },
        class: "inline-flex items-center px-4 py-2 border border-amber-300 rounded-md shadow-sm text-sm font-medium text-amber-700 bg-amber-50 hover:bg-amber-100" %>
    <%= link_to "Issue Certificate", new_network_certificate_path(@network),
        class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-ztlp-600 hover:bg-ztlp-700" %>
  </div>

  <!-- Expiring Certificates Warning -->
  <% if @expiring_certs.any? %>
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <h3 class="text-sm font-semibold text-amber-800 mb-2">⚠️ Certificates Expiring Soon</h3>
      <ul class="space-y-1">
        <% @expiring_certs.each do |cert| %>
          <li class="text-sm text-amber-700">
            <%= link_to cert.hostname, network_certificate_path(@network, cert), class: "underline hover:text-amber-900" %>
            — expires in <%= cert.days_until_expiry %> days (<%= cert.expires_at.strftime("%Y-%m-%d") %>)
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- TLS Configuration -->
  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">🔒 TLS Configuration</h2>
    <p class="text-sm text-gray-500 mb-4">
      ZTLP provides double encryption: TLS on the client device (browser ↔ agent) plus Noise_XX encryption 
      in the tunnel (agent ↔ gateway). Configure TLS settings for your deployment.
    </p>
    
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      <!-- Agent-Side TLS -->
      <div class="border border-gray-200 rounded-lg p-4">
        <h3 class="text-sm font-semibold text-gray-900 mb-2">Agent-Side TLS (Client Devices)</h3>
        <p class="text-xs text-gray-500 mb-3">
          Local HTTPS between the browser/app and the ZTLP agent on the same device.
          Certs are automatically issued by the ZTLP CA and trusted via the installed root cert.
        </p>
        <dl class="space-y-2">
          <div class="flex justify-between">
            <dt class="text-xs text-gray-500">Status</dt>
            <dd class="text-xs font-medium text-green-600">Enabled by default</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-xs text-gray-500">Cert directory</dt>
            <dd class="text-xs font-mono text-gray-600">~/.ztlp/certs/</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-xs text-gray-500">Auto-issue</dt>
            <dd class="text-xs font-medium text-green-600">Yes</dd>
          </div>
        </dl>
      </div>
      
      <!-- Internal TLS (Gateway → Backend) -->
      <div class="border border-gray-200 rounded-lg p-4">
        <h3 class="text-sm font-semibold text-gray-900 mb-2">Internal TLS (Gateway → Backend)</h3>
        <p class="text-xs text-gray-500 mb-3">
          Optional encrypted last-mile between the gateway and backend services inside your Docker network.
          Eliminates plaintext even on internal networks.
        </p>
        <dl class="space-y-2">
          <div class="flex justify-between">
            <dt class="text-xs text-gray-500">Status</dt>
            <dd class="text-xs font-medium text-gray-500">Optional</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-xs text-gray-500">Config key</dt>
            <dd class="text-xs font-mono text-gray-600">tls_enabled: true</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-xs text-gray-500">Port</dt>
            <dd class="text-xs font-mono text-gray-600">8443 (internal only)</dd>
          </div>
        </dl>
      </div>
    </div>
    
    <!-- Signing Oracle -->
    <div class="mt-6 border border-indigo-200 rounded-lg p-4 bg-indigo-50">
      <h3 class="text-sm font-semibold text-indigo-900 mb-2">🔐 Signing Oracle (Hardware-Backed CA)</h3>
      <p class="text-xs text-indigo-700 mb-3">
        For production deployments, use the Signing Oracle to keep the root CA key on a 
        YubiKey or TPM. The root key never exists on disk — signing operations go through
        the hardware via a ZTLP tunnel.
      </p>
      <div class="flex items-center space-x-4">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
          Not configured
        </span>
        <a href="https://github.com/priceflex/ztlp/blob/main/docs/SIGNING-ORACLE.md"
           target="_blank"
           class="text-xs font-medium text-indigo-700 underline hover:text-indigo-900">
          Setup guide →
        </a>
      </div>
    </div>
  </div>

<% else %>
  <!-- Not Initialized -->
  <div class="bg-white shadow rounded-lg p-8 text-center">
    <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
    </svg>
    <h3 class="mt-2 text-sm font-semibold text-gray-900">No Certificate Authority</h3>
    <p class="mt-1 text-sm text-gray-500">Initialize the internal CA to enable TLS certificate management and passwordless authentication.</p>
    <% if @status[:error] %>
      <p class="mt-2 text-sm text-red-600"><%= @status[:error] %></p>
    <% end %>
    <div class="mt-6">
      <%= button_to "Initialize CA", init_network_ca_path(@network),
          method: :post,
          class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-ztlp-600 hover:bg-ztlp-700" %>
    </div>
  </div>
<% end %>
