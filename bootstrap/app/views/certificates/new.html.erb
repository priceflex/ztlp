<div class="mb-6">
  <nav class="text-sm text-gray-500 mb-2">
    <%= link_to @network.name, @network, class: "hover:text-gray-700" %> /
    <%= link_to "Certificates", network_certificates_path(@network), class: "hover:text-gray-700" %> /
    <span class="text-gray-700">Issue Certificate</span>
  </nav>
  <h1 class="text-2xl font-bold text-gray-900">Issue Certificate</h1>
  <p class="mt-1 text-sm text-gray-500">Issue a new TLS certificate signed by the ZTLP internal CA</p>
</div>

<div class="bg-white shadow rounded-lg p-6">
  <%= form_with(model: @certificate, url: network_certificates_path(@network), class: "space-y-6") do |f| %>
    <div>
      <%= f.label :hostname, class: "block text-sm font-medium text-gray-700" %>
      <p class="text-xs text-gray-500 mt-1">The hostname or service name (e.g., webapp.corp.ztlp)</p>
      <%= f.text_field :hostname,
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm",
          placeholder: "webapp.corp.ztlp",
          required: true %>
    </div>

    <div>
      <%= f.label :days, "Validity (days)", class: "block text-sm font-medium text-gray-700" %>
      <p class="text-xs text-gray-500 mt-1">Certificate validity period. Default: 90 days.</p>
      <%= f.number_field :days,
          value: 90,
          min: 1,
          max: 365,
          class: "mt-1 block w-32 rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :assurance_level, class: "block text-sm font-medium text-gray-700" %>
      <p class="text-xs text-gray-500 mt-1">Authentication assurance level for this certificate</p>
      <%= f.select :assurance_level,
          [["Software (file-based key)", "software"],
           ["Device-bound (TPM/Keychain)", "device-bound"],
           ["Hardware (YubiKey/SmartCard)", "hardware"]],
          {},
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :notes, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :notes,
          rows: 3,
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm",
          placeholder: "Optional notes about this certificate" %>
    </div>

    <div class="flex justify-end space-x-3">
      <%= link_to "Cancel", network_certificates_path(@network),
          class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
      <%= f.submit "Issue Certificate",
          class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-ztlp-600 hover:bg-ztlp-700" %>
    </div>
  <% end %>
</div>
