<div class="mb-8">
  <h1 class="text-2xl font-bold text-gray-900">ZTLP Bootstrap Dashboard</h1>
  <p class="mt-1 text-sm text-gray-500">Manage your Zero Trust Layer Protocol deployments</p>
</div>

<!-- Stats -->
<div class="grid grid-cols-1 gap-5 sm:grid-cols-4 mb-8">
  <div class="rounded-lg bg-white px-4 py-5 shadow sm:p-6">
    <dt class="truncate text-sm font-medium text-gray-500">Networks</dt>
    <dd class="mt-1 text-3xl font-semibold tracking-tight text-gray-900"><%= @networks.count %></dd>
  </div>
  <div class="rounded-lg bg-white px-4 py-5 shadow sm:p-6">
    <dt class="truncate text-sm font-medium text-gray-500">Machines</dt>
    <dd class="mt-1 text-3xl font-semibold tracking-tight text-gray-900"><%= @machine_stats[:total] %></dd>
  </div>
  <div class="rounded-lg bg-white px-4 py-5 shadow sm:p-6">
    <dt class="truncate text-sm font-medium text-gray-500">Ready</dt>
    <dd class="mt-1 text-3xl font-semibold tracking-tight text-green-600"><%= @machine_stats[:ready] %></dd>
  </div>
  <div class="rounded-lg bg-white px-4 py-5 shadow sm:p-6">
    <dt class="truncate text-sm font-medium text-gray-500">Errors</dt>
    <dd class="mt-1 text-3xl font-semibold tracking-tight text-red-600"><%= @machine_stats[:error] %></dd>
  </div>
</div>

<div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
  <!-- Networks -->
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:px-6 flex justify-between items-center">
      <h3 class="text-lg font-medium text-gray-900">Networks</h3>
      <%= link_to "New Network", new_network_path, class: "rounded-md bg-ztlp-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-ztlp-500" %>
    </div>
    <ul class="divide-y divide-gray-200">
      <% @networks.each do |network| %>
        <li class="px-4 py-4 sm:px-6">
          <div class="flex items-center justify-between">
            <div>
              <%= link_to network.name, network, class: "text-sm font-medium text-ztlp-600 hover:text-ztlp-500" %>
              <p class="text-xs text-gray-500"><%= network.zone %></p>
            </div>
            <div class="flex items-center space-x-2">
              <span class="text-xs text-gray-500"><%= network.machines.count %> machines</span>
              <%= status_badge(network.status) %>
            </div>
          </div>
        </li>
      <% end %>
      <% if @networks.empty? %>
        <li class="px-4 py-8 sm:px-6 text-center text-gray-500">
          No networks yet. <%= link_to "Create one", new_network_path, class: "text-ztlp-600 hover:text-ztlp-500" %>.
        </li>
      <% end %>
    </ul>
  </div>

  <!-- Recent Deployments -->
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:px-6 flex justify-between items-center">
      <h3 class="text-lg font-medium text-gray-900">Recent Deployments</h3>
      <%= link_to "View All", deployments_path, class: "text-sm text-ztlp-600 hover:text-ztlp-500" %>
    </div>
    <ul class="divide-y divide-gray-200">
      <% @recent_deployments.each do |dep| %>
        <li class="px-4 py-4 sm:px-6">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-gray-900">
                <%= dep.machine.hostname %> / <%= dep.component %>
              </p>
              <p class="text-xs text-gray-500"><%= dep.machine.network.name %></p>
            </div>
            <div class="flex items-center space-x-2">
              <span class="text-xs text-gray-500"><%= time_ago_short(dep.created_at) %></span>
              <%= status_badge(dep.status) %>
            </div>
          </div>
        </li>
      <% end %>
      <% if @recent_deployments.empty? %>
        <li class="px-4 py-8 sm:px-6 text-center text-gray-500">No deployments yet.</li>
      <% end %>
    </ul>
  </div>
</div>

<!-- Recent Audit Log -->
<div class="mt-8 bg-white shadow rounded-lg">
  <div class="px-4 py-5 sm:px-6 flex justify-between items-center">
    <h3 class="text-lg font-medium text-gray-900">Recent Activity</h3>
    <%= link_to "View All", audit_logs_path, class: "text-sm text-ztlp-600 hover:text-ztlp-500" %>
  </div>
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Time</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Action</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Target</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @recent_audit_logs.each do |log| %>
        <tr>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= log.created_at.strftime("%b %d %H:%M") %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= log.action %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= "#{log.target_type}##{log.target_id}" if log.target_type %></td>
          <td class="px-6 py-4 whitespace-nowrap"><%= status_badge(log.status) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
