<%
  all_pages = [
    { slug: "overview", title: "Overview" },
    { slug: "networks", title: "Networks" },
    { slug: "machines", title: "Machines & Infrastructure" },
    { slug: "users", title: "Users" },
    { slug: "devices", title: "Devices" },
    { slug: "groups", title: "Groups & Policies" },
    { slug: "enrollment", title: "Enrollment" },
    { slug: "deployment", title: "Deployment" }
  ]
  idx = all_pages.index { |p| p[:slug] == current_page }
  prev_page = idx && idx > 0 ? all_pages[idx - 1] : nil
  next_page = idx && idx < all_pages.length - 1 ? all_pages[idx + 1] : nil
%>

<div class="mt-12 pt-6 border-t border-gray-200 flex items-center justify-between">
  <div>
    <% if prev_page %>
      <%= link_to doc_page_path(page: prev_page[:slug]), class: "flex items-center gap-2 text-sm text-gray-500 hover:text-ztlp-600 transition" do %>
        <span>←</span>
        <span>Previous: <%= prev_page[:title] %></span>
      <% end %>
    <% end %>
  </div>
  <div>
    <% if next_page %>
      <%= link_to doc_page_path(page: next_page[:slug]), class: "flex items-center gap-2 text-sm text-gray-500 hover:text-ztlp-600 transition" do %>
        <span>Next: <%= next_page[:title] %></span>
        <span>→</span>
      <% end %>
    <% end %>
  </div>
</div>
