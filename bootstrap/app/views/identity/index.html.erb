<div class="mb-6">
  <nav class="text-sm text-gray-500 mb-2">
    <%= link_to @network.name, @network, class: "hover:text-gray-700" %> /
    <span class="text-gray-700">Identity & Access Management</span>
  </nav>
  <div class="sm:flex sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Identity & Access Management</h1>
      <p class="mt-1 text-sm text-gray-500"><%= @network.zone %></p>
    </div>
    <div class="mt-4 sm:mt-0 flex space-x-3">
      <%= link_to network_enrollment_index_path(@network), class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" do %>
        🎫 Enrollment
      <% end %>
      <%= link_to network_identity_providers_path(@network), class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" do %>
        🔑 Identity Providers
      <% end %>
    </div>
  </div>
</div>

<!-- Tab Navigation -->
<div class="border-b border-gray-200 mb-6">
  <nav class="-mb-px flex space-x-1 overflow-x-auto" aria-label="Tabs">
    <%= link_to identity_network_path(@network, tab: "overview"),
        class: identity_tab_class(@tab, "overview"),
        data: { turbo_frame: "identity_content" } do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" /></svg>
      Overview
    <% end %>
    <%= link_to identity_network_path(@network, tab: "users"),
        class: identity_tab_class(@tab, "users"),
        data: { turbo_frame: "identity_content" } do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
      Users
      <span class="ml-1 rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600"><%= @users.count %></span>
    <% end %>
    <%= link_to identity_network_path(@network, tab: "devices"),
        class: identity_tab_class(@tab, "devices"),
        data: { turbo_frame: "identity_content" } do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25A2.25 2.25 0 015.25 3h13.5A2.25 2.25 0 0121 5.25z" /></svg>
      Devices
      <span class="ml-1 rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600"><%= @devices.count %></span>
    <% end %>
    <%= link_to identity_network_path(@network, tab: "groups"),
        class: identity_tab_class(@tab, "groups"),
        data: { turbo_frame: "identity_content" } do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>
      Groups
      <span class="ml-1 rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600"><%= @groups.count %></span>
    <% end %>
  </nav>
</div>

<!-- Tab Content -->
<%= turbo_frame_tag "identity_content" do %>
  <% case @tab %>
  <% when "overview" %>
    <%= render "identity/tab_overview" %>
  <% when "users" %>
    <%= render "identity/tab_users" %>
  <% when "devices" %>
    <%= render "identity/tab_devices" %>
  <% when "groups" %>
    <%= render "identity/tab_groups" %>
  <% end %>
<% end %>
