<div class="mb-6">
  <nav class="text-sm text-gray-500 mb-2">
    <%= link_to @network.name, @network, class: "hover:text-gray-700" %> /
    <span class="text-gray-700">Identity Providers</span>
  </nav>
  <div class="sm:flex sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Identity Providers</h1>
      <p class="mt-1 text-sm text-gray-500">Configure OIDC providers for self-service device enrollment</p>
    </div>
    <div class="mt-4 sm:mt-0">
      <%= link_to "Add Provider", new_network_identity_provider_path(@network),
          class: "rounded-md bg-ztlp-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-ztlp-500" %>
    </div>
  </div>
</div>

<div class="bg-white shadow rounded-lg">
  <% if @identity_providers.any? %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Domains</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Auto-Create</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @identity_providers.each do |idp| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap">
              <%= link_to idp.name, network_identity_provider_path(@network, idp),
                  class: "text-sm font-medium text-ztlp-600 hover:text-ztlp-500" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= idp.display_type %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 font-mono">
              <%= idp.allowed_domains.presence || "Any" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
              <% if idp.auto_create_users %>
                <span class="text-green-600">✓ (<%= idp.role_default %>)</span>
              <% else %>
                <span class="text-gray-400">—</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <%= status_badge(idp.enabled? ? "active" : "disabled") %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
              <%= link_to "Edit", edit_network_identity_provider_path(@network, idp),
                  class: "text-ztlp-600 hover:text-ztlp-500 mr-3" %>
              <%= button_to "Delete", network_identity_provider_path(@network, idp),
                  method: :delete,
                  class: "text-red-600 hover:text-red-500",
                  data: { turbo_confirm: "Delete identity provider '#{idp.name}'?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="px-6 py-8 text-center text-gray-500">
      No identity providers configured yet.
      <%= link_to "Add one", new_network_identity_provider_path(@network), class: "text-ztlp-600" %>.
    </div>
  <% end %>
</div>

<% if @identity_providers.any?(&:enabled?) %>
  <div class="mt-6 bg-blue-50 rounded-lg p-4">
    <h3 class="text-sm font-medium text-blue-800">Self-Service Enrollment URL</h3>
    <p class="mt-1 text-sm text-blue-700">
      Share this link with users:
      <code class="bg-blue-100 px-2 py-0.5 rounded font-mono text-xs"><%= network_enroll_url(@network) %></code>
    </p>
  </div>
<% end %>
