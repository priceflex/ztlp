<div class="max-w-lg mx-auto mt-10">
  <div class="text-center mb-8">
    <span class="text-4xl">🔐</span>
    <h1 class="mt-4 text-2xl font-bold text-gray-900">Enroll Your Device</h1>
    <p class="mt-2 text-sm text-gray-500">
      Sign in with your organization account to enroll a device on
      <span class="font-mono font-medium"><%= @network.zone %></span>
    </p>
  </div>

  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">Choose your sign-in method</h2>

    <div class="space-y-3">
      <% @identity_providers.each do |idp| %>
        <%= button_to "/auth/#{idp.omniauth_strategy}",
            method: :post,
            class: "w-full flex items-center justify-center space-x-3 rounded-md px-4 py-3 text-sm font-semibold shadow-sm ring-1 ring-inset #{idp.google? ? 'bg-white text-gray-700 ring-gray-300 hover:bg-gray-50' : 'bg-ztlp-600 text-white ring-ztlp-600 hover:bg-ztlp-500'}" do %>
          <% if idp.google? %>
            <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            <span>Sign in with Google</span>
          <% else %>
            <span>🏢</span>
            <span>Sign in with <%= idp.name %></span>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="mt-6 text-center">
    <p class="text-xs text-gray-400">
      After signing in, you'll receive an enrollment token for your device.
    </p>
    <%= link_to "← Back to #{@network.name}", @network, class: "mt-2 block text-sm text-ztlp-600 hover:text-ztlp-500" %>
  </div>
</div>
