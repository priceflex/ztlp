<div class="max-w-2xl">
  <%= form_with(model: [network, machine], class: "space-y-6") do |form| %>
    <% if machine.errors.any? %>
      <div class="rounded-md bg-red-50 p-4">
        <h3 class="text-sm font-medium text-red-800"><%= pluralize(machine.errors.count, "error") %> prevented saving:</h3>
        <ul class="mt-2 list-disc list-inside text-sm text-red-700">
          <% machine.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= form.label :hostname, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :hostname, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm sm:text-sm px-3 py-2 border", placeholder: "ns1.office" %>
      </div>
      <div>
        <%= form.label :ip_address, "IP Address", class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :ip_address, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm sm:text-sm font-mono px-3 py-2 border", placeholder: "10.0.1.10" %>
      </div>
    </div>

    <fieldset class="border rounded-md p-4">
      <legend class="text-sm font-medium text-gray-700 px-2">SSH Configuration</legend>
      <div class="space-y-4 mt-2">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= form.label :ssh_user, "SSH User", class: "block text-sm font-medium text-gray-700" %>
            <%= form.text_field :ssh_user, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm sm:text-sm px-3 py-2 border" %>
          </div>
          <div>
            <%= form.label :ssh_port, "SSH Port", class: "block text-sm font-medium text-gray-700" %>
            <%= form.number_field :ssh_port, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm sm:text-sm px-3 py-2 border" %>
          </div>
        </div>

        <div>
          <%= form.label :ssh_auth_method, "Auth Method", class: "block text-sm font-medium text-gray-700" %>
          <%= form.select :ssh_auth_method, [["SSH Key", "key"], ["Password", "password"], ["SSH Agent", "agent"]], {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm sm:text-sm px-3 py-2 border" %>
        </div>

        <div>
          <%= form.label :ssh_private_key_ciphertext, "SSH Private Key", class: "block text-sm font-medium text-gray-700" %>
          <%= form.text_area :ssh_private_key_ciphertext, rows: 4, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm sm:text-sm font-mono px-3 py-2 border", placeholder: "-----BEGIN OPENSSH PRIVATE KEY-----\n..." %>
          <p class="mt-1 text-xs text-gray-500">Encrypted at rest. Only decrypted during SSH sessions.</p>
        </div>
      </div>
    </fieldset>

    <fieldset class="border rounded-md p-4">
      <legend class="text-sm font-medium text-gray-700 px-2">Roles</legend>
      <p class="text-xs text-gray-500 mb-3">Select which ZTLP components to deploy on this machine</p>
      <div class="space-y-2">
        <% Machine::VALID_ROLES.each do |role| %>
          <label class="flex items-center space-x-3">
            <input type="checkbox" name="machine[role_checks][]" value="<%= role %>"
                   <%= "checked" if machine.role_list.include?(role) %>
                   class="h-4 w-4 rounded border-gray-300 text-ztlp-600 focus:ring-ztlp-500"
                   onchange="updateRoles()">
            <span class="text-sm font-medium text-gray-700">
              <% if role == "ns" %>NS (Name Service) — DNS-like identity resolution
              <% elsif role == "relay" %>Relay — Encrypted packet routing
              <% elsif role == "gateway" %>Gateway — ZTLP-to-TCP bridge
              <% end %>
            </span>
          </label>
        <% end %>
      </div>
      <%= form.hidden_field :roles, id: "roles_field" %>
    </fieldset>

    <!-- Gateway Configuration (shown when gateway role is selected) -->
    <fieldset id="gateway_config_section" class="border rounded-md p-4" style="display: none;">
      <legend class="text-sm font-medium text-gray-700 px-2">Gateway Configuration</legend>
      <p class="text-xs text-gray-500 mb-3">Configure backends and access policies for the ZTLP gateway</p>
      <div class="space-y-4 mt-2">
        <div>
          <%= form.label :gateway_backends, "Backends", class: "block text-sm font-medium text-gray-700" %>
          <%= form.text_area :gateway_backends, rows: 3, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm sm:text-sm font-mono px-3 py-2 border", placeholder: "beta:127.0.0.1:80\napi:127.0.0.1:3000" %>
          <p class="mt-1 text-xs text-gray-500">One per line. Format: <code class="bg-gray-100 px-1 rounded">name:host:port</code> (e.g., <code class="bg-gray-100 px-1 rounded">beta:127.0.0.1:80</code>)</p>
        </div>
        <div>
          <%= form.label :gateway_policies, "Policies", class: "block text-sm font-medium text-gray-700" %>
          <%= form.text_area :gateway_policies, rows: 3, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm sm:text-sm font-mono px-3 py-2 border", placeholder: "*:beta\nsteves-macbook.techrockstars.ztlp:api" %>
          <p class="mt-1 text-xs text-gray-500">One per line. Format: <code class="bg-gray-100 px-1 rounded">identity:backend</code> — use <code class="bg-gray-100 px-1 rounded">*</code> for any authenticated identity (e.g., <code class="bg-gray-100 px-1 rounded">*:beta</code>)</p>
        </div>
      </div>
    </fieldset>

    <script>
      function updateRoles() {
        const checked = [...document.querySelectorAll('input[name="machine[role_checks][]"]:checked')].map(el => el.value);
        document.getElementById('roles_field').value = checked.join(',');

        // Show/hide gateway config section based on gateway role selection
        const gatewaySection = document.getElementById('gateway_config_section');
        if (gatewaySection) {
          gatewaySection.style.display = checked.includes('gateway') ? 'block' : 'none';
        }
      }
      // Initialize on load
      document.addEventListener('DOMContentLoaded', updateRoles);
    </script>

    <div class="flex items-center space-x-4">
      <%= form.submit class: "rounded-md bg-ztlp-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-ztlp-500 cursor-pointer" %>
      <%= link_to "Cancel", network_path(network), class: "text-sm text-gray-600 hover:text-gray-500" %>
    </div>
  <% end %>
</div>
