<div class="mb-6">
  <nav class="text-sm text-gray-500 mb-2">
    <%= link_to @network.name, @network, class: "hover:text-gray-700" %> /
  </nav>
  <div class="sm:flex sm:items-center sm:justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Machines</h1>
    <%= link_to "Add Machine", new_network_machine_path(@network), class: "rounded-md bg-ztlp-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-ztlp-500" %>
  </div>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Hostname</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">IP</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Roles</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @machines.each do |machine| %>
        <tr>
          <td class="px-6 py-4"><%= link_to machine.hostname, network_machine_path(@network, machine), class: "text-ztlp-600 hover:text-ztlp-500 font-medium" %></td>
          <td class="px-6 py-4 font-mono text-sm text-gray-500"><%= machine.ip_address %></td>
          <td class="px-6 py-4"><%= role_badges(machine.roles) %></td>
          <td class="px-6 py-4"><%= status_badge(machine.status) %></td>
          <td class="px-6 py-4 text-right text-sm space-x-2">
            <%= link_to "View", network_machine_path(@network, machine), class: "text-ztlp-600 hover:text-ztlp-500" %>
            <%= link_to "Edit", edit_network_machine_path(@network, machine), class: "text-gray-600 hover:text-gray-500" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
