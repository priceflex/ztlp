<div class="mb-6">
  <div class="sm:flex sm:items-center sm:justify-between">
    <div>
      <nav class="text-sm text-gray-500 mb-2">
        <%= link_to @network.name, @network, class: "hover:text-gray-700" %> /
      </nav>
      <h1 class="text-2xl font-bold text-gray-900"><%= @machine.hostname %></h1>
      <p class="mt-1 text-sm text-gray-500 font-mono"><%= @machine.ip_address %>:<%= @machine.ssh_port %></p>
    </div>
    <div class="mt-4 sm:mt-0 flex items-center space-x-3">
      <%= ztlp_tunnel_indicator(@machine) %>
      <%= button_to "Test SSH", test_connection_network_machine_path(@network, @machine), method: :post, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
      <%= button_to "Health Check", health_check_network_machine_path(@network, @machine), method: :post, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
      <%= button_to "🔒 Check ZTLP", check_ztlp_tunnel_network_machine_path(@network, @machine), method: :post, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
      <%= link_to "Edit", edit_network_machine_path(@network, @machine), class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
    </div>
  </div>
</div>

<!-- Machine Info -->
<div class="bg-white shadow rounded-lg mb-8">
  <div class="px-4 py-5 sm:px-6">
    <h3 class="text-lg font-medium text-gray-900">Machine Details</h3>
  </div>
  <dl class="divide-y divide-gray-200">
    <div class="px-4 py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
      <dt class="text-sm font-medium text-gray-500">Status</dt>
      <dd class="mt-1 sm:mt-0 sm:col-span-2"><%= status_badge(@machine.status) %></dd>
    </div>
    <div class="px-4 py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
      <dt class="text-sm font-medium text-gray-500">Roles</dt>
      <dd class="mt-1 sm:mt-0 sm:col-span-2"><%= role_badges(@machine.roles) %></dd>
    </div>
    <div class="px-4 py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
      <dt class="text-sm font-medium text-gray-500">SSH</dt>
      <dd class="mt-1 sm:mt-0 sm:col-span-2 font-mono text-sm"><%= @machine.ssh_user %>@<%= @machine.ip_address %>:<%= @machine.ssh_port %> (<%= @machine.ssh_auth_method %>)</dd>
    </div>
    <div class="px-4 py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
      <dt class="text-sm font-medium text-gray-500">Docker</dt>
      <dd class="mt-1 sm:mt-0 sm:col-span-2"><%= @machine.docker_installed? ? "✓ Installed" : "Not installed" %></dd>
    </div>
    <div class="px-4 py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
      <dt class="text-sm font-medium text-gray-500">Last Health Check</dt>
      <dd class="mt-1 sm:mt-0 sm:col-span-2"><%= time_ago_short(@machine.last_health_check_at) %></dd>
    </div>
    <div class="px-4 py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
      <dt class="text-sm font-medium text-gray-500">ZTLP Tunnel</dt>
      <dd class="mt-1 sm:mt-0 sm:col-span-2">
        <div class="flex items-center gap-3">
          <%= ztlp_tunnel_indicator(@machine) %>
          <% if @machine.ztlp_tunnel_latency_ms.present? && @machine.ztlp_tunnel_reachable? %>
            <span class="text-xs text-gray-500"><%= @machine.ztlp_tunnel_latency_ms %>ms</span>
          <% end %>
          <% if @machine.ztlp_tunnel_checked_at.present? %>
            <span class="text-xs text-gray-400">checked <%= time_ago_short(@machine.ztlp_tunnel_checked_at) %></span>
          <% end %>
        </div>
        <% if @machine.ztlp_tunnel_error.present? && !@machine.ztlp_tunnel_reachable? %>
          <p class="mt-1 text-xs text-red-500"><%= @machine.ztlp_tunnel_error %></p>
        <% end %>
      </dd>
    </div>
    <% if @machine.last_error.present? %>
      <div class="px-4 py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500">Last Error</dt>
        <dd class="mt-1 sm:mt-0 sm:col-span-2 text-red-600 text-sm"><%= @machine.last_error %></dd>
      </div>
    <% end %>
  </dl>
</div>

<!-- Deploy Components -->
<div class="bg-white shadow rounded-lg mb-8">
  <div class="px-4 py-5 sm:px-6">
    <h3 class="text-lg font-medium text-gray-900">Components</h3>
  </div>
  <div class="px-4 py-4 sm:px-6 grid grid-cols-1 sm:grid-cols-3 gap-4">
    <% @machine.role_list.each do |role| %>
      <div class="border rounded-lg p-4">
        <div class="flex items-center justify-between mb-3">
          <h4 class="font-medium"><%= role.upcase %></h4>
          <% dep = @machine.latest_deployment_for(role) %>
          <%= status_badge(dep&.status || "not deployed") if dep %>
        </div>
        <%= button_to "Deploy #{role}", provision_network_machine_path(@network, @machine, component: role), method: :post, class: "w-full rounded-md bg-ztlp-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-ztlp-500", data: { turbo_confirm: "Deploy #{role} to #{@machine.hostname}?" } %>
      </div>
    <% end %>
  </div>
</div>

<!-- Gateway-specific Details -->
<% if @machine.role_list.include?("gateway") %>
<div class="bg-white shadow rounded-lg mb-8 p-6">
  <h3 class="text-lg font-medium text-gray-900 mb-4">🌐 Gateway Configuration</h3>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
    <div class="rounded-md bg-emerald-50 border border-emerald-200 p-4">
      <h4 class="text-xs font-medium text-gray-500 uppercase mb-3">Backends</h4>
      <% if @machine.gateway_backends.present? %>
        <div class="space-y-2">
          <% @machine.gateway_backends.strip.split("\n").each do |line| %>
            <% parts = line.strip.split(":") %>
            <% if parts.length >= 3 %>
              <div class="flex items-center justify-between text-xs">
                <span class="font-medium text-gray-900"><%= parts[0] %></span>
                <span class="font-mono text-gray-500"><%= parts[1..].join(":") %></span>
              </div>
            <% else %>
              <div class="text-xs font-mono text-gray-700"><%= line.strip %></div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="text-xs text-gray-400 italic">No backends configured. <br>Edit this machine to add backends (e.g., beta:127.0.0.1:80)</p>
      <% end %>
    </div>
    <div class="rounded-md bg-emerald-50 border border-emerald-200 p-4">
      <h4 class="text-xs font-medium text-gray-500 uppercase mb-3">Access Policies</h4>
      <% if @machine.gateway_policies.present? %>
        <div class="space-y-2">
          <% @machine.gateway_policies.strip.split("\n").each do |line| %>
            <% parts = line.strip.split(":") %>
            <% if parts.length >= 2 %>
              <div class="flex items-center justify-between text-xs">
                <span class="font-mono text-gray-500"><%= parts[0] == "*" ? "Any authenticated" : parts[0] %></span>
                <span class="font-medium text-gray-900">→ <%= parts[1] %></span>
              </div>
            <% else %>
              <div class="text-xs font-mono text-gray-700"><%= line.strip %></div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="text-xs text-gray-400 italic">No policies configured. <br>Edit this machine to add policies (e.g., *:beta)</p>
      <% end %>
    </div>
  </div>
  <div class="rounded-md bg-gray-50 border border-gray-200 p-4">
    <h4 class="text-xs font-medium text-gray-500 uppercase mb-3">Gateway Settings</h4>
    <div class="space-y-2 text-xs">
      <div class="flex justify-between"><span class="text-gray-500">Listen Port</span><span class="font-mono text-gray-900"><%= SshProvisioner::ZTLP_PORTS['gateway'][:tcp] %> (TCP)</span></div>
      <div class="flex justify-between"><span class="text-gray-500">Metrics Port</span><span class="font-mono text-gray-900"><%= SshProvisioner::ZTLP_PORTS['gateway'][:metrics] %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Networking</span><span class="font-medium text-green-600">Host Network</span></div>
    </div>
  </div>
</div>
<% end %>

<!-- Relay-specific Details -->
<% if @machine.role_list.include?("relay") %>
<div class="bg-white shadow rounded-lg mb-8 p-6">
  <h3 class="text-lg font-medium text-gray-900 mb-4">⚡ Relay Configuration</h3>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
    <div class="rounded-md bg-indigo-50 border border-indigo-200 p-4">
      <h4 class="text-xs font-medium text-gray-500 uppercase mb-3">Relay Settings</h4>
      <div class="space-y-2 text-xs">
        <div class="flex justify-between"><span class="text-gray-500">Listen Port</span><span class="font-mono text-gray-900">4433 (UDP)</span></div>
        <div class="flex justify-between"><span class="text-gray-500">Max Connections</span><span class="font-mono text-gray-900">1,000</span></div>
        <div class="flex justify-between"><span class="text-gray-500">Buffer Size</span><span class="font-mono text-gray-900">64 KB</span></div>
        <div class="flex justify-between"><span class="text-gray-500">Keepalive</span><span class="font-mono text-gray-900">30s</span></div>
      </div>
    </div>
    <div class="rounded-md bg-indigo-50 border border-indigo-200 p-4">
      <h4 class="text-xs font-medium text-gray-500 uppercase mb-3">Mesh Settings</h4>
      <div class="space-y-2 text-xs">
        <div class="flex justify-between"><span class="text-gray-500">Mesh Mode</span><span class="font-medium text-green-600">Enabled</span></div>
        <div class="flex justify-between"><span class="text-gray-500">Virtual Nodes</span><span class="font-mono text-gray-900">128</span></div>
        <div class="flex justify-between"><span class="text-gray-500">Heartbeat</span><span class="font-mono text-gray-900">5s</span></div>
        <div class="flex justify-between"><span class="text-gray-500">Probe Interval</span><span class="font-mono text-gray-900">10s</span></div>
        <div class="flex justify-between"><span class="text-gray-500">Admission Tokens</span><span class="font-medium text-green-600">Enabled</span></div>
        <div class="flex justify-between"><span class="text-gray-500">RAT TTL</span><span class="font-mono text-gray-900">3,600s</span></div>
      </div>
    </div>
  </div>
  <% other_relays = @network.machines.with_role("relay").where.not(id: @machine.id) %>
  <% ns_machines = @network.machines.with_role("ns") %>
  <% gateways = @network.machines.with_role("gateway") %>
  <% if other_relays.any? || ns_machines.any? || gateways.any? %>
    <div class="rounded-md bg-gray-50 border border-gray-200 p-4">
      <h4 class="text-xs font-medium text-gray-500 uppercase mb-3">Related Infrastructure</h4>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        <% if ns_machines.any? %>
          <div>
            <div class="text-xs text-gray-500 mb-1">NS Servers</div>
            <% ns_machines.each do |ns| %>
              <div class="flex items-center gap-1 text-xs">
                <%= health_status_icon(ns.health_status) %>
                <%= link_to ns.hostname, network_machine_path(@network, ns), class: "text-gray-700 hover:text-ztlp-600" %>
              </div>
            <% end %>
          </div>
        <% end %>
        <% if other_relays.any? %>
          <div>
            <div class="text-xs text-gray-500 mb-1">Mesh Peers</div>
            <% other_relays.each do |r| %>
              <div class="flex items-center gap-1 text-xs">
                <%= health_status_icon(r.health_status) %>
                <%= link_to r.hostname, network_machine_path(@network, r), class: "text-gray-700 hover:text-ztlp-600" %>
              </div>
            <% end %>
          </div>
        <% end %>
        <% if gateways.any? %>
          <div>
            <div class="text-xs text-gray-500 mb-1">Gateways</div>
            <% gateways.each do |gw| %>
              <div class="flex items-center gap-1 text-xs">
                <%= health_status_icon(gw.health_status) %>
                <%= link_to gw.hostname, network_machine_path(@network, gw), class: "text-gray-700 hover:text-ztlp-600" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
<% end %>

<!-- Deployment History -->
<div class="bg-white shadow rounded-lg">
  <div class="px-4 py-5 sm:px-6">
    <h3 class="text-lg font-medium text-gray-900">Deployment History</h3>
  </div>
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Component</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Duration</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Time</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Log</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @deployments.each do |dep| %>
        <tr>
          <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= dep.component %></td>
          <td class="px-6 py-4 whitespace-nowrap"><%= status_badge(dep.status) %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= dep.duration ? "%.1fs" % dep.duration : "—" %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= dep.created_at.strftime("%b %d %H:%M") %></td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
            <%= link_to "View Log", deployment_path(dep), class: "text-ztlp-600 hover:text-ztlp-500" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
