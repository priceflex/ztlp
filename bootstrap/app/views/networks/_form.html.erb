<div class="max-w-2xl">
  <%= form_with(model: network, class: "space-y-6") do |form| %>
    <% if network.errors.any? %>
      <div class="rounded-md bg-red-50 p-4">
        <h3 class="text-sm font-medium text-red-800"><%= pluralize(network.errors.count, "error") %> prevented saving:</h3>
        <ul class="mt-2 list-disc list-inside text-sm text-red-700">
          <% network.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm px-3 py-2 border", placeholder: "My Office Network" %>
    </div>

    <div>
      <%= form.label :zone, "Zone Name", class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :zone, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm font-mono px-3 py-2 border", placeholder: "office.acme.ztlp" %>
      <p class="mt-1 text-xs text-gray-500">Lowercase letters, numbers, hyphens, and dots. Example: office.acme.ztlp</p>
    </div>

    <div>
      <%= form.label :notes, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :notes, rows: 3, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm px-3 py-2 border", placeholder: "Optional notes about this network..." %>
    </div>

    <div class="flex items-center space-x-4">
      <%= form.submit class: "rounded-md bg-ztlp-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-ztlp-500 cursor-pointer" %>
      <%= link_to "Cancel", networks_path, class: "text-sm text-gray-600 hover:text-gray-500" %>
    </div>
  <% end %>
</div>
