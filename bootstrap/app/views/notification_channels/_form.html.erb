<%= form_with(model: [@network, @channel], class: "space-y-6") do |f| %>
  <% if @channel.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <div class="text-sm text-red-800">
        <ul class="list-disc list-inside">
          <% @channel.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <!-- Channel Type Selection -->
  <div>
    <label class="block text-sm font-medium text-gray-700 mb-3">Channel Type</label>
    <div class="grid grid-cols-3 gap-4">
      <% NotificationChannel::CHANNEL_TYPES.each do |type| %>
        <label class="relative flex cursor-pointer rounded-lg border bg-white p-4 shadow-sm focus:outline-none
          <%= @channel.channel_type == type ? 'border-ztlp-600 ring-2 ring-ztlp-600' : 'border-gray-300' %>">
          <%= f.radio_button :channel_type, type, class: "sr-only", data: { action: "change->notification-form#typeChanged" } %>
          <span class="flex flex-1 flex-col items-center text-center">
            <span class="text-2xl">
              <%= { "email" => "📧", "webhook" => "🔗", "slack" => "💬" }[type] %>
            </span>
            <span class="mt-1 block text-sm font-medium text-gray-900"><%= type.capitalize %></span>
          </span>
        </label>
      <% end %>
    </div>
  </div>

  <!-- Name -->
  <div>
    <label for="notification_channel_name" class="block text-sm font-medium text-gray-700">Name</label>
    <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm", placeholder: "e.g., Team Alerts Email" %>
  </div>

  <!-- Email Config -->
  <% config = @channel.parsed_config %>
  <div id="config-email" class="space-y-4 <%= 'hidden' unless @channel.channel_type == 'email' %>">
    <h3 class="text-sm font-medium text-gray-900">📧 Email Configuration</h3>
    <div>
      <label class="block text-sm font-medium text-gray-700">Recipients (comma-separated)</label>
      <input type="text" name="config[recipients]" value="<%= Array(config['recipients']).join(', ') %>" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm" placeholder="admin@example.com, team@example.com">
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700">From Address</label>
      <input type="text" name="config[from]" value="<%= config['from'] %>" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm" placeholder="ztlp@yourdomain.com">
    </div>
    <details class="mt-2">
      <summary class="text-sm font-medium text-gray-600 cursor-pointer">Advanced SMTP Settings</summary>
      <div class="mt-3 space-y-3 pl-4 border-l-2 border-gray-200">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">SMTP Server</label>
            <input type="text" name="config[smtp_server]" value="<%= config['smtp_server'] %>" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm" placeholder="smtp.gmail.com">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">SMTP Port</label>
            <input type="number" name="config[smtp_port]" value="<%= config['smtp_port'] || 587 %>" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">SMTP User</label>
          <input type="text" name="config[smtp_user]" value="<%= config['smtp_user'] %>" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">SMTP Password</label>
          <input type="password" name="config[smtp_password]" value="<%= config['smtp_password'] %>" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm">
        </div>
      </div>
    </details>
  </div>

  <!-- Webhook Config -->
  <div id="config-webhook" class="space-y-4 <%= 'hidden' unless @channel.channel_type == 'webhook' %>">
    <h3 class="text-sm font-medium text-gray-900">🔗 Webhook Configuration</h3>
    <div>
      <label class="block text-sm font-medium text-gray-700">Webhook URL</label>
      <input type="url" name="config[url]" value="<%= config['url'] %>" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm" placeholder="https://hooks.example.com/...">
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700">HTTP Method</label>
      <select name="config[method]" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm">
        <option value="POST" <%= 'selected' if config['method'] == 'POST' || config['method'].blank? %>>POST</option>
        <option value="PUT" <%= 'selected' if config['method'] == 'PUT' %>>PUT</option>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700">Custom Headers (JSON)</label>
      <textarea name="config[headers]" rows="2" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm font-mono text-xs" placeholder='{"Content-Type": "application/json"}'><%= (config['headers'] || {}).to_json %></textarea>
    </div>
  </div>

  <!-- Slack Config -->
  <div id="config-slack" class="space-y-4 <%= 'hidden' unless @channel.channel_type == 'slack' %>">
    <h3 class="text-sm font-medium text-gray-900">💬 Slack Configuration</h3>
    <div>
      <label class="block text-sm font-medium text-gray-700">Webhook URL</label>
      <input type="url" name="config[webhook_url]" value="<%= config['webhook_url'] %>" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm" placeholder="https://hooks.slack.com/services/...">
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700">Channel (optional)</label>
      <input type="text" name="config[channel]" value="<%= config['channel'] %>" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm" placeholder="#alerts">
    </div>
  </div>

  <!-- Severity Filter -->
  <div>
    <label class="block text-sm font-medium text-gray-700">Severity Filter</label>
    <select name="notification_channel[severity_filter]" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ztlp-500 focus:ring-ztlp-500 sm:text-sm">
      <% NotificationChannel::SEVERITY_FILTERS.each do |sf| %>
        <option value="<%= sf %>" <%= 'selected' if @channel.severity_filter == sf %>><%= sf.titleize %></option>
      <% end %>
    </select>
  </div>

  <!-- Event Filter -->
  <div>
    <label class="block text-sm font-medium text-gray-700 mb-2">Event Filter (leave unchecked for all events)</label>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
      <% selected_events = @channel.event_types %>
      <% NotificationService::EVENTS.each do |event| %>
        <label class="flex items-center gap-2 text-sm text-gray-700">
          <input type="checkbox" name="events[]" value="<%= event %>" <%= 'checked' if selected_events.include?(event) %> class="rounded border-gray-300 text-ztlp-600 focus:ring-ztlp-500">
          <span><%= event.humanize %></span>
        </label>
      <% end %>
    </div>
    <%= f.hidden_field :event_filter, id: "event_filter_field" %>
  </div>

  <div class="flex items-center justify-between pt-4 border-t border-gray-200">
    <div class="flex gap-3">
      <%= f.submit @channel.new_record? ? "Create Channel" : "Update Channel", class: "rounded-md bg-ztlp-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-ztlp-500 cursor-pointer" %>
      <%= link_to "Cancel", network_notification_channels_path(@network), class: "rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
    </div>
  </div>
<% end %>

<script>
  // Collect checked events into hidden field before submit
  document.querySelector('form')?.addEventListener('submit', function(e) {
    const checked = Array.from(document.querySelectorAll('input[name="events[]"]:checked')).map(cb => cb.value);
    document.getElementById('event_filter_field').value = checked.join(',');
  });
</script>
