<div class="w-full max-w-md">
  <div class="bg-white rounded-xl shadow-2xl p-8">
    <!-- Branding -->
    <div class="text-center mb-8">
      <span class="text-5xl">🔐</span>
      <h1 class="mt-4 text-2xl font-bold text-gray-900">ZTLP Bootstrap</h1>
      <p class="mt-2 text-sm text-gray-500">Sign in to manage your zero-trust network</p>
    </div>

    <!-- Flash messages -->
    <% if alert %>
      <div class="mb-6 rounded-lg bg-red-50 border border-red-200 p-4">
        <div class="flex items-center">
          <span class="text-red-500 mr-2">✗</span>
          <p class="text-sm font-medium text-red-800"><%= alert %></p>
        </div>
      </div>
    <% end %>
    <% if notice %>
      <div class="mb-6 rounded-lg bg-green-50 border border-green-200 p-4">
        <div class="flex items-center">
          <span class="text-green-500 mr-2">✓</span>
          <p class="text-sm font-medium text-green-800"><%= notice %></p>
        </div>
      </div>
    <% end %>

    <!-- Login form -->
    <%= form_with url: login_path, method: :post, local: true, data: { turbo: false } do |f| %>
      <div class="space-y-5">
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700">Email address</label>
          <input type="email" name="email" id="email" autocomplete="email" required
                 value="<%= params[:email] %>"
                 class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-900 shadow-sm placeholder-gray-400 focus:border-ztlp-500 focus:ring-2 focus:ring-ztlp-500 focus:ring-offset-0 sm:text-sm"
                 placeholder="admin@example.com">
        </div>

        <div>
          <label for="password" class="block text-sm font-medium text-gray-700">Password</label>
          <input type="password" name="password" id="password" autocomplete="current-password" required
                 class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-900 shadow-sm placeholder-gray-400 focus:border-ztlp-500 focus:ring-2 focus:ring-ztlp-500 focus:ring-offset-0 sm:text-sm"
                 placeholder="••••••••">
        </div>

        <button type="submit"
                class="w-full flex justify-center rounded-lg bg-ztlp-600 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-ztlp-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ztlp-600 transition-colors">
          Sign In
        </button>
      </div>
    <% end %>
  </div>

  <p class="mt-6 text-center text-xs text-ztlp-100">
    Zero Trust Local Perimeter &middot; Secure Access
  </p>
</div>
