<div class="mb-6">
  <nav class="text-sm text-gray-500 mb-2">
    <%= link_to @network.name, @network, class: "hover:text-gray-700" %> /
  </nav>
  <div class="sm:flex sm:items-center sm:justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Enrollment Tokens</h1>
    <%= link_to "Generate Token", new_network_token_path(@network), class: "rounded-md bg-ztlp-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-ztlp-500" %>
  </div>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Token ID</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Uses</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Expires</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @tokens.each do |token| %>
        <tr>
          <td class="px-6 py-4 whitespace-nowrap font-mono text-sm">
            <%= link_to token.token_id, network_token_path(@network, token), class: "text-ztlp-600 hover:text-ztlp-500" %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= token.current_uses %>/<%= token.max_uses %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= token.expires_at.strftime("%b %d %H:%M") %></td>
          <td class="px-6 py-4 whitespace-nowrap"><%= status_badge(token.status) %></td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-2">
            <%= link_to "View", network_token_path(@network, token), class: "text-ztlp-600 hover:text-ztlp-500" %>
            <% if token.usable? %>
              <%= button_to "Revoke", revoke_network_token_path(@network, token), method: :post, class: "text-red-600 hover:text-red-500", data: { turbo_confirm: "Revoke this token?" } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
