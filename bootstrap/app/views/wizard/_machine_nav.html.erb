<div id="wizard-nav" class="mt-6 flex justify-between">
  <%= link_to "← Back", wizard_new_path, class: "rounded-md bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-200" %>
  <% if machines.select(&:persisted?).any? %>
    <%= link_to "Next: Security & TLS →", wizard_security_path, class: "rounded-md bg-ztlp-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-ztlp-500" %>
  <% else %>
    <span class="rounded-md bg-gray-300 px-4 py-2 text-sm font-semibold text-gray-500 cursor-not-allowed" title="Add at least one machine">Next: Security & TLS →</span>
  <% end %>
</div>
