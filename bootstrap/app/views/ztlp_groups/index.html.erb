<div class="mb-6">
  <nav class="text-sm text-gray-500 mb-2">
    <%= link_to @network.name, @network, class: "hover:text-gray-700" %> /
    <span class="text-gray-700">Groups</span>
  </nav>
  <div class="sm:flex sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Groups</h1>
      <p class="mt-1 text-sm text-gray-500">ZTLP access groups on <%= @network.zone %></p>
    </div>
    <div class="mt-4 sm:mt-0">
      <%= link_to "Create Group", new_network_ztlp_group_path(@network), class: "rounded-md bg-ztlp-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-ztlp-500" %>
    </div>
  </div>
</div>

<div class="bg-white shadow rounded-lg">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Description</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Members</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @groups.each do |group| %>
        <tr>
          <td class="px-6 py-4 whitespace-nowrap">
            <%= link_to group.name, network_ztlp_group_path(@network, group), class: "text-sm font-medium text-ztlp-600 hover:text-ztlp-500" %>
          </td>
          <td class="px-6 py-4 text-sm text-gray-500"><%= group.description || "—" %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= group.member_count %></td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
            <%= link_to "View", network_ztlp_group_path(@network, group), class: "text-ztlp-600 hover:text-ztlp-500" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @groups.empty? %>
    <div class="px-6 py-8 text-center text-gray-500">
      No groups yet. <%= link_to "Create one", new_network_ztlp_group_path(@network), class: "text-ztlp-600" %>.
    </div>
  <% end %>
</div>
