<div class="mb-6">
  <nav class="text-sm text-gray-500 mb-2">
    <%= link_to @network.name, @network, class: "hover:text-gray-700" %> /
    <%= link_to "Groups", network_ztlp_groups_path(@network), class: "hover:text-gray-700" %> /
    <span class="text-gray-700"><%= @group.name %></span>
  </nav>
  <div class="sm:flex sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @group.name %></h1>
      <% if @group.description.present? %>
        <p class="mt-1 text-sm text-gray-500"><%= @group.description %></p>
      <% end %>
    </div>
    <div class="mt-4 sm:mt-0 flex space-x-3">
      <%= button_to "Delete Group", network_ztlp_group_path(@network, @group), method: :delete,
          class: "rounded-md bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500",
          data: { turbo_confirm: "Delete group '#{@group.name}'? Members will be removed." } %>
    </div>
  </div>
</div>

<!-- Members -->
<div class="bg-white shadow rounded-lg mb-8">
  <div class="px-4 py-5 sm:px-6 flex justify-between items-center">
    <h3 class="text-lg font-medium text-gray-900">Members (<%= @members.count %>)</h3>
  </div>

  <% if @members.any? %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Role</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @members.each do |member| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap">
              <%= link_to member.name, network_ztlp_user_path(@network, member), class: "text-sm font-medium text-ztlp-600 hover:text-ztlp-500" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <% role_color = case member.role
                 when "admin" then "bg-red-100 text-red-800"
                 when "tech" then "bg-yellow-100 text-yellow-800"
                 else "bg-gray-100 text-gray-800"
                 end %>
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= role_color %>"><%= member.role %></span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap"><%= status_badge(member.status) %></td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
              <%= button_to "Remove", remove_member_network_ztlp_group_path(@network, @group, user_id: member.id), method: :delete,
                  class: "text-red-600 hover:text-red-500 text-sm",
                  data: { turbo_confirm: "Remove #{member.name} from #{@group.name}?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="px-6 py-4 text-sm text-gray-500">No members in this group.</div>
  <% end %>
</div>

<!-- Add Member -->
<% if @available_users.any? %>
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg font-medium text-gray-900">Add Member</h3>
    </div>
    <div class="px-6 py-4">
      <%= form_with(url: add_member_network_ztlp_group_path(@network, @group), method: :post, class: "flex items-center space-x-4") do |form| %>
        <div class="flex-1">
          <select name="user_id" class="block w-full rounded-md border-gray-300 shadow-sm sm:text-sm px-3 py-2 border">
            <% @available_users.each do |user| %>
              <option value="<%= user.id %>"><%= user.name %> (<%= user.role %>)</option>
            <% end %>
          </select>
        </div>
        <%= form.submit "Add to Group", class: "rounded-md bg-ztlp-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-ztlp-500 cursor-pointer" %>
      <% end %>
    </div>
  </div>
<% end %>
