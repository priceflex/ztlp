<div class="mb-6">
  <nav class="text-sm text-gray-500 mb-2">
    <%= link_to @network.name, @network, class: "hover:text-gray-700" %> /
    <span class="text-gray-700">Users</span>
  </nav>
  <div class="sm:flex sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Users</h1>
      <p class="mt-1 text-sm text-gray-500">ZTLP identity users on <%= @network.zone %></p>
    </div>
    <div class="mt-4 sm:mt-0">
      <%= link_to "Add User", new_network_ztlp_user_path(@network), class: "rounded-md bg-ztlp-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-ztlp-500" %>
    </div>
  </div>
</div>

<div class="bg-white shadow rounded-lg">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Role</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Devices</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Groups</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @users.each do |user| %>
        <tr>
          <td class="px-6 py-4 whitespace-nowrap">
            <%= link_to user.name, network_ztlp_user_path(@network, user), class: "text-sm font-medium text-ztlp-600 hover:text-ztlp-500" %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <% role_color = case user.role
               when "admin" then "bg-red-100 text-red-800"
               when "tech" then "bg-yellow-100 text-yellow-800"
               else "bg-gray-100 text-gray-800"
               end %>
            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= role_color %>"><%= user.role %></span>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= user.email || "—" %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= user.ztlp_devices.count %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= user.ztlp_groups.count %></td>
          <td class="px-6 py-4 whitespace-nowrap"><%= status_badge(user.status) %></td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
            <%= link_to "View", network_ztlp_user_path(@network, user), class: "text-ztlp-600 hover:text-ztlp-500" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @users.empty? %>
    <div class="px-6 py-8 text-center text-gray-500">
      No users yet. <%= link_to "Add one", new_network_ztlp_user_path(@network), class: "text-ztlp-600" %>.
    </div>
  <% end %>
</div>
