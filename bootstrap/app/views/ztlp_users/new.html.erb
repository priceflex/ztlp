<div class="mb-6">
  <nav class="text-sm text-gray-500 mb-2">
    <%= link_to @network.name, @network, class: "hover:text-gray-700" %> /
    <%= link_to "Users", network_ztlp_users_path(@network), class: "hover:text-gray-700" %> /
  </nav>
  <h1 class="text-2xl font-bold text-gray-900">Add User</h1>
  <p class="mt-1 text-sm text-gray-500">Create a new ZTLP identity user on <%= @network.zone %></p>
</div>

<div class="max-w-2xl">
  <%= form_with(model: [@network, @user], url: network_ztlp_users_path(@network), class: "space-y-6") do |form| %>
    <% if @user.errors.any? %>
      <div class="rounded-md bg-red-50 p-4">
        <h3 class="text-sm font-medium text-red-800"><%= pluralize(@user.errors.count, "error") %> prevented saving:</h3>
        <ul class="mt-2 list-disc list-inside text-sm text-red-700">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm sm:text-sm px-3 py-2 border", placeholder: "alice" %>
      <p class="mt-1 text-xs text-gray-500">Unique identity name within this network</p>
    </div>

    <div>
      <%= form.label :role, class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :role, [["User", "user"], ["Tech", "tech"], ["Admin", "admin"]], {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm sm:text-sm px-3 py-2 border" %>
    </div>

    <div>
      <%= form.label :email, class: "block text-sm font-medium text-gray-700" %>
      <%= form.email_field :email, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm sm:text-sm px-3 py-2 border", placeholder: "alice@example.com" %>
      <p class="mt-1 text-xs text-gray-500">Optional contact email</p>
    </div>

    <div class="flex items-center space-x-4">
      <%= form.submit "Create User", class: "rounded-md bg-ztlp-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-ztlp-500 cursor-pointer" %>
      <%= link_to "Cancel", network_ztlp_users_path(@network), class: "text-sm text-gray-600 hover:text-gray-500" %>
    </div>
  <% end %>
</div>
