<div class="mb-6">
  <nav class="text-sm text-gray-500 mb-2">
    <%= link_to @network.name, @network, class: "hover:text-gray-700" %> /
    <%= link_to "Users", network_ztlp_users_path(@network), class: "hover:text-gray-700" %> /
    <span class="text-gray-700"><%= @user.name %></span>
  </nav>
  <div class="sm:flex sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @user.name %></h1>
      <p class="mt-1 text-sm text-gray-500"><%= @user.email || "No email" %></p>
    </div>
    <div class="mt-4 sm:mt-0 flex space-x-3">
      <% if @user.active? %>
        <%= button_to "Revoke User", network_ztlp_user_path(@network, @user), method: :delete,
            class: "rounded-md bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500",
            data: { turbo_confirm: "Revoke user '#{@user.name}'? This cannot be undone." } %>
      <% end %>
    </div>
  </div>
  <div class="mt-2 flex space-x-3">
    <% role_color = case @user.role
       when "admin" then "bg-red-100 text-red-800"
       when "tech" then "bg-yellow-100 text-yellow-800"
       else "bg-gray-100 text-gray-800"
       end %>
    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= role_color %>"><%= @user.role %></span>
    <%= status_badge(@user.status) %>
  </div>
</div>

<% if @user.revoked? %>
  <div class="rounded-md bg-red-50 p-4 mb-6">
    <p class="text-sm text-red-800">
      <strong>Revoked</strong> <%= time_ago_short(@user.revoked_at) %>
      <% if @user.revocation_reason.present? %>
        — <%= @user.revocation_reason %>
      <% end %>
    </p>
  </div>
<% end %>

<!-- Linked Devices -->
<div class="bg-white shadow rounded-lg mb-8">
  <div class="px-4 py-5 sm:px-6">
    <h3 class="text-lg font-medium text-gray-900">Devices (<%= @devices.count %>)</h3>
  </div>
  <% if @devices.any? %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Machine</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @devices.each do |device| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap">
              <%= link_to device.name, network_ztlp_device_path(@network, device), class: "text-sm font-medium text-ztlp-600 hover:text-ztlp-500" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= device.machine&.hostname || "—" %></td>
            <td class="px-6 py-4 whitespace-nowrap"><%= status_badge(device.status) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="px-6 py-4 text-sm text-gray-500">No devices linked to this user.</div>
  <% end %>
</div>

<!-- Group Memberships -->
<div class="bg-white shadow rounded-lg">
  <div class="px-4 py-5 sm:px-6">
    <h3 class="text-lg font-medium text-gray-900">Groups (<%= @groups.count %>)</h3>
  </div>
  <% if @groups.any? %>
    <ul class="divide-y divide-gray-200">
      <% @groups.each do |group| %>
        <li class="px-6 py-4">
          <%= link_to group.name, network_ztlp_group_path(@network, group), class: "text-sm font-medium text-ztlp-600 hover:text-ztlp-500" %>
          <% if group.description.present? %>
            <span class="text-sm text-gray-500 ml-2"><%= group.description %></span>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="px-6 py-4 text-sm text-gray-500">Not a member of any groups.</div>
  <% end %>
</div>
