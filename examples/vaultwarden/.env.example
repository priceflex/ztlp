# ─────────────────────────────────────────────────────────────
# Vaultwarden + ZTLP — Environment Configuration
# ─────────────────────────────────────────────────────────────
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Generate secrets with:
#   openssl rand -hex 32    (for 64 hex char secrets)
#   openssl rand -base64 48 (for admin tokens)

# ── ZTLP Zone ──────────────────────────────────────────────
# Your ZTLP zone name. This is the logical namespace for all
# identities in this deployment.
ZTLP_ZONE=home.ztlp

# ── ZTLP Enrollment Secret ────────────────────────────────
# 64 hex characters (32 bytes). Used to generate enrollment
# tokens for new devices. Keep this secret — anyone with it
# can create enrollment tokens.
#
# Generate: openssl rand -hex 32
ZTLP_ENROLLMENT_SECRET=

# ── ZTLP Header HMAC Secret ──────────────────────────────
# Shared secret used to sign X-ZTLP-* identity headers.
# The gateway signs headers with this secret; backends can
# verify them to ensure headers weren't forged.
#
# Generate: openssl rand -hex 32
ZTLP_HEADER_HMAC_SECRET=

# ── Vaultwarden ───────────────────────────────────────────
# Admin panel token. Set this to enable the /admin panel.
# Leave empty to disable the admin panel entirely.
#
# Generate: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=

# Domain that Vaultwarden uses for generating URLs in emails,
# attachment links, etc. This should match the ZTLP service name
# your clients will use.
DOMAIN=https://vault.home.ztlp

# ── TLS Termination (optional) ────────────────────────────
# Enable TLS to allow browser access via HTTPS + mTLS.
# This is OPTIONAL — the primary access mode is still ZTLP/UDP
# via the agent (zero exposed ports). TLS adds a second path
# for direct browser access without installing the ZTLP agent.
#
# Uncomment these to enable:
# ZTLP_GATEWAY_TLS_ENABLED=true
# ZTLP_GATEWAY_TLS_PORT=8443
#
# Certificate files (generated by `ztlp admin cert issue`):
# ZTLP_GATEWAY_TLS_CERT_FILE=/etc/ztlp/certs/vault.home.ztlp.pem
# ZTLP_GATEWAY_TLS_KEY_FILE=/etc/ztlp/certs/vault.home.ztlp-key.pem
# ZTLP_GATEWAY_TLS_CA_CERT_FILE=/etc/ztlp/ca/chain.pem

# ── Logging ───────────────────────────────────────────────
# Log level for ZTLP components: debug, info, warn, error
ZTLP_LOG_LEVEL=info
